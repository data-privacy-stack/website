---
import "../styles/tokens.css";
import { getCollection } from "astro:content";

const githubOrg = "https://github.com/data-privacy-stack";
const presidioDocs = "https://presidio.dataprivacystack.org";
const presidioRepo = "https://github.com/data-privacy-stack/presidio";
const mvgRepo = "https://github.com/data-privacy-stack/MVG";
const discordUrl = "https://discord.gg/MewtBGFquB";
const contactEmail = "contact@dataprivacystack.org";
const ccByUrl = "https://creativecommons.org/licenses/by/4.0/";

const principles = [
  { title: "Open", body: "Permissively licensed, community-driven, and developed in the open." },
  { title: "Transparent", body: "Clear about what's detected, how, and why. No black boxes." },
  { title: "Composable", body: "Independent building blocks you can adopt one piece at a time." },
];

const postKey = (e) => e.id ?? e.slug ?? "";
const posts = (await getCollection("docs"))
  .filter((e) => {
    const k = postKey(e);
    return k.startsWith("blog/") && !k.endsWith("/index");
  })
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Data Privacy Stack: open, transparent tools for private data handling</title>
    <meta name="description" content="Open, transparent tools for private data handling." />
    <link rel="icon" type="image/svg+xml" href="/octopus-icon.svg" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content="Data Privacy Stack" />
    <meta property="og:description" content="Open, transparent tools for private data handling." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dataprivacystack.org" />
    <script is:inline>
      // Set theme before paint to avoid a flash. Shares Starlight's key so the
      // choice carries over to the docs/blog pages.
      // Default is LIGHT; only an explicit toggle overrides it.
      (function () {
        try {
          let theme = localStorage.getItem("starlight-theme");
          if (theme !== "light" && theme !== "dark") {
            theme = "light";
            localStorage.setItem("starlight-theme", theme);
          }
          document.documentElement.dataset.theme = theme;
          if (
            window.matchMedia &&
            !window.matchMedia("(prefers-reduced-motion: reduce)").matches &&
            "IntersectionObserver" in window
          ) {
            document.documentElement.classList.add("reveal-ready");
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="nav">
      <a class="brand" href="#top">
        <img class="brand-mark" src="/octopus-icon.svg" alt="" width="28" height="28" aria-hidden="true" />
        <span class="brand-label">Data Privacy Stack</span>
      </a>
      <nav id="nav-links" class="links">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#ecosystem">Ecosystem</a>
        <a href="#governance">Governance</a>
        <a href="#blog">Blog</a>
        <a href="#community">Community</a>
        <a href={presidioDocs}>Docs</a>
      </nav>
      <a class="icon-btn" href={githubOrg} aria-label="GitHub" title="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23a11.51 11.51 0 0 1 3.003-.404c1.018.005 2.045.138 3.003.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .321.218.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
      <a class="icon-btn" href={discordUrl} aria-label="Discord" title="Discord">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
      </a>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button id="menu-toggle" class="menu-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links">
        <svg class="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
    </header>

    <main id="top">
      <!-- Hero -->
      <section class="hero">
        <h1 class="site-title">Data Privacy Stack</h1>
        <div class="hero-row">
          <div class="hero-logo-wrap">
            <img
              class="hero-logo"
              src="/octopus.svg"
              alt="Data Privacy Stack octopus mascot"
              width="490"
              height="649"
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="hero-copy">
            <p class="tagline">Open, transparent tools for private data handling</p>
            <div class="cta">
              <a class="btn primary" href={presidioDocs}>Explore Presidio</a>
              <a class="btn" href={githubOrg}>View on GitHub</a>
            </div>
            <ul class="badges" aria-label="Capabilities">
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                PII detection
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.7 5.1A11 11 0 0 1 12 5c5 0 9 4.5 10 7a13.2 13.2 0 0 1-2.2 3.1"/><path d="M6.6 6.6C3.9 8.2 2.4 10.6 2 12c1 2.5 5 7 10 7a10.4 10.4 0 0 0 5.4-1.6"/><path d="m2 2 20 20"/><path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"/></svg>
                Redaction
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
                De-identification
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 0 20 15.3 15.3 0 0 1 0-20Z"/></svg>
                Multi-language
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m16 18 6-6-6-6"/><path d="m8 6-6 6 6 6"/></svg>
                Open source
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- About / Mission -->
      <section id="about" class="section sec-a">
        <p class="mission-statement">
          Our mission is to democratize privacy technology by putting open, transparent
          tools for protecting sensitive data within everyone's reach, and strengthening
          the privacy and security of individuals and organizations alike.
        </p>
        <p class="lead">
          The Data Privacy Stack is a community-led home for open, transparent tools that
          help engineers handle private data responsibly, starting with
          <strong>Presidio</strong> for PII detection and anonymization, with room to grow.
        </p>
        <h2>Guiding principles</h2>
        <div class="cards">
          {principles.map((p) => (
            <div class="card">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Projects -->
      <section id="projects" class="section sec-b">
        <h2>Projects</h2>
        <div class="cards">
          <article class="card project">
            <h3>Presidio</h3>
            <p>Detect and anonymize PII in text, images, and structured data using
              redaction, masking, replacement, encryption, and synthetic surrogates.</p>
            <div class="card-links">
              <a class="primary" href={presidioDocs}>Docs&nbsp;→</a>
              <a href={presidioRepo}>GitHub</a>
              <a href="https://pypi.org/project/presidio-analyzer/">PyPI</a>
            </div>
          </article>
          <article class="card placeholder">
            <h3>More coming</h3>
            <p>The stack is growing. Want to propose or contribute a project?
              <a href="#community">Get involved&nbsp;→</a></p>
          </article>
        </div>
      </section>

      <!-- Ecosystem (logos via Magic logo_search; structure from ui-ux-pro-max) -->
      <section id="ecosystem" class="section sec-a">
        <h2>Runs where you work</h2>
        <p class="lead">From a Python import to Docker and Kubernetes, drop the stack into the
          tools and pipelines you already use.</p>
        <ul class="eco-logos" aria-label="Ecosystem and integrations">
          <li>
            <svg role="img" aria-label="Python" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="16 16 32 32"><path fill="url(#dps-py-a)" d="M31.885 16c-8.124 0-7.617 3.523-7.617 3.523l.01 3.65h7.752v1.095H21.197S16 23.678 16 31.876c0 8.196 4.537 7.906 4.537 7.906h2.708v-3.804s-.146-4.537 4.465-4.537h7.688s4.32.07 4.32-4.175v-7.019S40.374 16 31.885 16zm-4.275 2.454a1.394 1.394 0 1 1 0 2.79 1.393 1.393 0 0 1-1.395-1.395c0-.771.624-1.395 1.395-1.395z"/><path fill="url(#dps-py-b)" d="M32.115 47.833c8.124 0 7.617-3.523 7.617-3.523l-.01-3.65H31.97v-1.095h10.832S48 40.155 48 31.958c0-8.197-4.537-7.906-4.537-7.906h-2.708v3.803s.146 4.537-4.465 4.537h-7.688s-4.32-.07-4.32 4.175v7.019s-.656 4.247 7.833 4.247zm4.275-2.454a1.393 1.393 0 0 1-1.395-1.395 1.394 1.394 0 1 1 1.395 1.395z"/><defs><linearGradient id="dps-py-a" x1="19.075" x2="34.898" y1="18.782" y2="34.658" gradientUnits="userSpaceOnUse"><stop stop-color="#387EB8"/><stop offset="1" stop-color="#366994"/></linearGradient><linearGradient id="dps-py-b" x1="28.809" x2="45.803" y1="28.882" y2="45.163" gradientUnits="userSpaceOnUse"><stop stop-color="#FFE052"/><stop offset="1" stop-color="#FFC331"/></linearGradient></defs></svg>
          </li>
          <li>
