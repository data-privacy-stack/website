---
import "../styles/tokens.css";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import prism from "../assets/prism.png";
import mark from "../assets/dps-mark.png";

const githubOrg = "https://github.com/data-privacy-stack";
const presidioDocs = "https://presidio.dataprivacystack.org";
const presidioRepo = "https://github.com/data-privacy-stack/presidio";
const mvgRepo = "https://github.com/data-privacy-stack/MVG";
const discordUrl = "https://discord.gg/MewtBGFquB";
const contactEmail = "contact@dataprivacystack.org";
const ccByUrl = "https://creativecommons.org/licenses/by/4.0/";

const principles = [
  { title: "Open", body: "Permissively licensed, community-driven, and developed in the open." },
  { title: "Transparent", body: "Clear about what's detected, how, and why — no black boxes." },
  { title: "Composable", body: "Independent building blocks you can adopt one piece at a time." },
];

const postKey = (e) => e.id ?? e.slug ?? "";
const posts = (await getCollection("docs"))
  .filter((e) => {
    const k = postKey(e);
    return k.startsWith("blog/") && !k.endsWith("/index");
  })
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Data Privacy Stack — open, transparent tools for private data handling</title>
    <meta name="description" content="Open, transparent tools for private data handling." />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content="Data Privacy Stack" />
    <meta property="og:description" content="Open, transparent tools for private data handling." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dataprivacystack.org" />
    <script is:inline>
      // Set theme before paint to avoid a flash. Shares Starlight's key so the
      // choice carries over to the docs/blog pages.
      // Default is DARK regardless of OS; only an explicit toggle overrides it.
      (function () {
        try {
          let theme = localStorage.getItem("starlight-theme");
          if (theme !== "light" && theme !== "dark") {
            theme = "dark";
            localStorage.setItem("starlight-theme", theme);
          }
          document.documentElement.dataset.theme = theme;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="nav">
      <a class="brand" href="#top">
        <Image class="brand-mark" src={mark} alt="" width={28} height={28} aria-hidden="true" />
        <span class="brand-label">Data Privacy Stack</span>
      </a>
      <nav id="nav-links" class="links">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#governance">Governance</a>
        <a href="#blog">Blog</a>
        <a href="#community">Community</a>
        <a href={presidioDocs}>Docs</a>
      </nav>
      <a class="icon-btn" href={githubOrg} aria-label="GitHub" title="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23a11.51 11.51 0 0 1 3.003-.404c1.018.005 2.045.138 3.003.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .321.218.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
      <a class="icon-btn" href={discordUrl} aria-label="Discord" title="Discord">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
      </a>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button id="menu-toggle" class="menu-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links">
        <svg class="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
    </header>

    <main id="top">
      <!-- Hero -->
      <section class="hero">
        <h1 class="site-title">Data Privacy Stack</h1>
        <div class="hero-row">
          <Image
            class="hero-logo"
            src={prism}
            alt=""
            widths={[400, 600, 900]}
            sizes="(max-width: 880px) 90vw, 520px"
            loading="eager"
          />
          <div class="hero-copy">
            <p class="tagline">Open, transparent tools for private data handling</p>
            <div class="cta">
              <a class="btn primary" href={presidioDocs}>Explore Presidio</a>
              <a class="btn" href={githubOrg}>View on GitHub</a>
            </div>
          </div>
        </div>
      </section>

      <!-- About / Mission -->
      <section id="about" class="section sec-a">
        <p class="mission-statement">
          Our mission is to democratize privacy technology — putting open, transparent
          tools for protecting sensitive data within everyone's reach, and strengthening
          the privacy and security of individuals and organizations alike.
        </p>
        <p class="lead">
          The Data Privacy Stack is a community-led home for open, transparent tools that
          help engineers handle private data responsibly — starting with
          <strong>Presidio</strong> for PII detection and anonymization, with room to grow.
        </p>
        <h2>Guiding principles</h2>
        <div class="cards">
          {principles.map((p) => (
            <div class="card">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Projects -->
      <section id="projects" class="section sec-b">
        <h2>Projects</h2>
        <div class="cards">
          <article class="card project">
            <h3>Presidio</h3>
            <p>Detect and anonymize PII in text, images, and structured data — through
              redaction, masking, replacement, encryption, and synthetic surrogates.</p>
            <div class="card-links">
              <a class="primary" href={presidioDocs}>Docs →</a>
              <a href={presidioRepo}>GitHub</a>
              <a href="https://pypi.org/project/presidio-analyzer/">PyPI</a>
            </div>
          </article>
          <article class="card placeholder">
            <h3>More coming</h3>
            <p>The stack is growing. Want to propose or contribute a project?
              <a href="#community">Get involved →</a></p>
          </article>
        </div>
      </section>

      <!-- Governance -->
      <section id="governance" class="section sec-a">
        <h2>Governance</h2>
        <p class="lead">
          The Data Privacy Stack follows a <strong>Minimum Viable Governance (MVG)</strong>
          model — a lightweight, two-tier structure that puts clear, consensus-based
          governance in place without heavyweight overhead.
        </p>
        <div class="cards">
          <div class="card">
            <h3>Technical Steering Committee</h3>
            <p>At the organization level, the TSC sets overall direction and coordinates
              across projects — technical roadmap, maintainer appointments, and governance
              policy.</p>
          </div>
          <div class="card">
            <h3>Project Maintainers</h3>
            <p>Each project is run by its maintainers through a lightweight,
              consensus-based process — reviewing contributions and keeping the project
              secure, maintained, and modern.</p>
          </div>
        </div>
        <p class="more">
          The authoritative governance documents — charter, code of conduct, steering
          committee, and per-project governance — live in the
          <a href={mvgRepo}>MVG repository</a>.
        </p>
      </section>

      <!-- Blog -->
      <section id="blog" class="section sec-b">
        <h2>Blog</h2>
        <p class="lead">News, releases, and notes from the community.</p>
        <ul class="posts">
          {posts.map((post) => (
            <li>
              <a href={`/${postKey(post)}/`}>{post.data.title}</a>
              {post.data.description && <span class="post-desc">{post.data.description}</span>}
            </li>
          ))}
        </ul>
      </section>

      <!-- Community -->
      <section id="community" class="section sec-a">
        <h2>Community</h2>
        <p class="lead">
          Contributions of all sizes are welcome — code, documentation, bug reports,
          feature ideas, and reviews. Development happens in the open across the
          <a href={githubOrg}>Data Privacy Stack organization</a>.
        </p>
        <div class="cards">
          <div class="card">
            <h3>Report or request</h3>
            <p>Open an issue in the relevant project repository to report a bug or request
              a feature.</p>
          </div>
          <div class="card">
            <h3>Contribute code</h3>
            <p>Pick up an open issue or propose a change. Presidio is developed at
              <a href={presidioRepo}>data-privacy-stack/presidio</a>; see its
              <code>CONTRIBUTING.md</code>.</p>
          </div>
          <div class="card">
            <h3>Shape the direction</h3>
            <p>Join the discussion, share use cases, and help set the roadmap under open
              <a href="#governance">governance</a>.</p>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="foot-cols">
        <div class="foot-brand">
          <div class="foot-brandline">
            <Image class="brand-mark" src={mark} alt="" width={28} height={28} aria-hidden="true" />
            <strong>Data Privacy Stack</strong>
          </div>
          <p>Open, transparent tools for private data handling.</p>
        </div>

        <div class="foot-col">
          <h4>Navigate</h4>
          <a href="#about">About</a>
          <a href="#projects">Projects</a>
          <a href="#governance">Governance</a>
          <a href="#blog">Blog</a>
          <a href="#community">Community</a>
          <a href={presidioDocs}>Docs</a>
        </div>

        <div class="foot-col">
          <h4>Projects</h4>
          <a href={presidioDocs}>Presidio docs</a>
          <a href={presidioRepo}>Presidio on GitHub</a>
          <a href="https://pypi.org/project/presidio-analyzer/">Presidio on PyPI</a>
        </div>

        <div class="foot-col">
          <h4>Get in touch</h4>
          <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
          <a href={discordUrl}>Discord</a>
          <a href={githubOrg}>GitHub</a>
          <div class="foot-social">
            <a class="icon-btn" href={githubOrg} aria-label="GitHub" title="GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23a11.51 11.51 0 0 1 3.003-.404c1.018.005 2.045.138 3.003.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .321.218.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            </a>
            <a class="icon-btn" href={discordUrl} aria-label="Discord" title="Discord">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
            </a>
            <a class="icon-btn" href={`mailto:${contactEmail}`} aria-label="Email" title="Email">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="foot-bottom">
        <span>© 2026 Data Privacy Stack</span>
        <span>
          Site content under <a href={ccByUrl}>CC&nbsp;BY&nbsp;4.0</a> ·
          project code is licensed per repository
        </span>
      </div>
    </footer>

    <script is:inline>
      const tbtn = document.getElementById("theme-toggle");
      tbtn?.addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem("starlight-theme", next); } catch (e) {}
      });

      // Mobile hamburger menu
      const nav = document.querySelector(".nav");
      const mbtn = document.getElementById("menu-toggle");
      const setMenu = (open) => {
        nav.classList.toggle("open", open);
        mbtn?.setAttribute("aria-expanded", open ? "true" : "false");
      };
      mbtn?.addEventListener("click", () =>
        setMenu(!nav.classList.contains("open"))
      );
      // Close after choosing a destination
      document
        .querySelectorAll("#nav-links a")
        .forEach((a) => a.addEventListener("click", () => setMenu(false)));
      // Close on Escape
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setMenu(false);
      });
    </script>

    <style>
      :root {
        --page-bg: linear-gradient(180deg, var(--dps-bg-start), var(--dps-bg-end));
        --text: var(--dps-ink);
        --text-muted: var(--dps-muted);
        --card-bg: #ffffff;
        --card-border: #c7ddec;
        --accent: var(--dps-teal);
        --accent-strong: var(--dps-teal-dark);
        --nav-bg: rgba(232, 243, 252, 0.78);
        --nav-border: rgba(18, 52, 59, 0.1);
        --hero-radius: 0px;
        --hero-shadow: none;
        /* alternating section bands (two close tones) */
        --sec-a: #c9e0f8;
        --sec-b: #bbd6f2;
        --sec-foot: #aecdee;
      }
      :root[data-theme="dark"] {
        --page-bg: #0d1b21;
        --text: #e7eef0;
        --text-muted: #9fb6bc;
        --card-bg: #15262d;
        --card-border: #28424b;
        --accent: #4bb0c4;
        --accent-strong: #8ad4e2;
        --nav-bg: rgba(13, 27, 33, 0.8);
        --nav-border: rgba(255, 255, 255, 0.08);
        --hero-radius: 16px;
        --hero-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
        --sec-a: #0f2026;
        --sec-b: #14282f;
        --sec-foot: #0a161b;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--dps-font);
        color: var(--text);
        background: var(--page-bg);
        background-attachment: fixed;
        min-height: 100vh;
      }
      a { color: var(--accent-strong); }

      /* Nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.7rem clamp(1rem, 5vw, 3rem);
        background: var(--nav-bg);
        backdrop-filter: saturate(180%) blur(10px);
        border-bottom: 1px solid var(--nav-border);
        flex-wrap: wrap;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 700;
        text-decoration: none;
        color: var(--text);
        margin-right: auto;
      }
      .brand-mark { width: 28px; height: 28px; border-radius: 6px; display: block; }
      .links { display: flex; gap: 1.05rem; flex-wrap: wrap; }
      .links a {
        text-decoration: none;
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.95rem;
      }
      .links a:hover { color: var(--accent-strong); }
      .theme-toggle {
        display: inline-grid;
        place-items: center;
        width: 36px; height: 36px;
        border-radius: 999px;
        border: 1px solid var(--card-border);
        background: var(--card-bg);
        color: var(--text);
        cursor: pointer;
      }
      .theme-toggle .icon-moon { display: none; }
      :root[data-theme="dark"] .theme-toggle .icon-sun { display: none; }
      :root[data-theme="dark"] .theme-toggle .icon-moon { display: block; }

      /* Icon links (GitHub, Discord, email) */
      .icon-btn {
        display: inline-grid;
        place-items: center;
        width: 36px; height: 36px;
        border-radius: 999px;
        color: var(--text-muted);
        transition: color 0.15s ease, background 0.15s ease;
      }
      .icon-btn:hover { color: var(--accent-strong); background: rgba(127, 127, 127, 0.12); }

      /* Hide brand wordmark on very small screens to make room for icons */
      @media (max-width: 420px) {
        .brand-label { display: none; }
      }

      /* Mobile hamburger (hidden on desktop) */
      .menu-toggle {
        display: none;
        place-items: center;
        width: 36px; height: 36px;
        border-radius: 999px;
        border: 1px solid var(--card-border);
        background: var(--card-bg);
        color: var(--text);
        cursor: pointer;
      }
      .menu-toggle .icon-close { display: none; }
      .nav.open .menu-toggle .icon-menu { display: none; }
      .nav.open .menu-toggle .icon-close { display: block; }

      @media (max-width: 880px) {
        .nav { flex-wrap: nowrap; }
        .menu-toggle { display: inline-grid; }
        .links {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          flex-direction: column;
          align-items: stretch;
          gap: 0;
          padding: 0.4rem 0;
          background: var(--nav-bg);
          backdrop-filter: saturate(180%) blur(10px);
          border-bottom: 1px solid var(--nav-border);
        }
        .nav.open .links { display: flex; }
        .links a {
          padding: 0.75rem clamp(1rem, 5vw, 3rem);
          font-size: 1rem;
        }
        .links a:hover { background: rgba(127, 127, 127, 0.1); color: var(--accent-strong); }
      }

      main { width: min(1040px, 92vw); margin: 0 auto; }

      /* Hero */
      .hero { padding: clamp(1.5rem, 5vw, 3rem) 1rem 2.5rem; }
      .site-title {
        text-align: center;
        margin: 0 0 clamp(1rem, 3vw, 2rem);
        font-size: clamp(2.4rem, 6vw, 4.5rem);
        line-height: 1.05;
        letter-spacing: -0.01em;
      }
      .hero-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: clamp(1rem, 4vw, 3rem);
        flex-wrap: wrap;
      }
      .hero-logo {
        width: min(480px, 90vw);
        height: auto;
        flex: 0 1 480px;
        border-radius: var(--hero-radius);
        box-shadow: var(--hero-shadow);
      }
      .hero-copy { flex: 1 1 340px; min-width: min(100%, 300px); text-align: left; }
      .tagline {
        margin: 0;
        font-size: clamp(1.5rem, 3.2vw, 2.4rem);
        line-height: 1.25;
        font-weight: 600;
        color: var(--text);
      }
      .cta { margin-top: 1.8rem; display: flex; gap: 0.9rem; flex-wrap: wrap; }
      @media (max-width: 880px) {
        .hero-copy { text-align: center; }
        .cta { justify-content: center; }
      }
      .btn {
        display: inline-block;
        padding: 0.7rem 1.4rem;
        border-radius: 999px;
        font-weight: 600;
        text-decoration: none;
        border: 1.5px solid var(--accent);
        color: var(--accent-strong);
        background: transparent;
        transition: transform 0.08s ease, box-shadow 0.15s ease;
      }
      .btn:hover { transform: translateY(-1px); box-shadow: 0 8px 18px rgba(31, 122, 140, 0.18); }
      .btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }

      /* Sections — full-bleed alternating background bands */
      .section {
        padding: clamp(2.5rem, 6vw, 4rem) 0;
        scroll-margin-top: 72px;
        background: var(--sec-bg);
        box-shadow: 0 0 0 100vmax var(--sec-bg);
        clip-path: inset(0 -100vmax);
      }
      .section.sec-a { --sec-bg: var(--sec-a); }
      .section.sec-b { --sec-bg: var(--sec-b); }

      /* Display font for headings + brand */
      .site-title,
      h2,
      .card h3,
      .brand,
      .tagline {
        font-family: var(--dps-font-display);
      }
      h2 {
        font-size: clamp(1.5rem, 3vw, 2rem);
        margin: 0 0 1.2rem;
        text-align: center;
      }
      .mission-statement {
        margin: 0 auto 1.5rem;
        max-width: 760px;
        font-size: clamp(1.2rem, 2.4vw, 1.6rem);
        line-height: 1.5;
        text-align: center;
        font-weight: 500;
      }
      .lead {
        margin: 0 auto 2rem;
        max-width: 720px;
        font-size: 1.1rem;
        line-height: 1.65;
        color: var(--text-muted);
        text-align: center;
      }
      .lead a, .more a { color: var(--accent-strong); }
      .more { text-align: center; color: var(--text-muted); margin-top: 1.5rem; }

      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.25rem;
      }
      .card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--dps-radius);
        padding: 1.4rem;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .card h3 { margin: 0; color: var(--accent-strong); }
      .card p { margin: 0; color: var(--text-muted); line-height: 1.55; }
      .card.placeholder { background: transparent; border-style: dashed; }
      .card.project h3 { color: var(--text); }
      .card-links { margin-top: auto; padding-top: 0.6rem; display: flex; gap: 1rem; font-weight: 600; }
      .card-links a { color: var(--accent-strong); text-decoration: none; }
      .card-links a.primary { color: var(--accent); }
      .card code, .card a { color: var(--accent-strong); }

      /* Blog list */
      .posts { list-style: none; padding: 0; margin: 0 auto; max-width: 760px; }
      .posts li {
        padding: 1rem 0;
        border-top: 1px solid var(--card-border);
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .posts li:first-child { border-top: none; }
      .posts a { font-weight: 600; font-size: 1.1rem; text-decoration: none; color: var(--accent-strong); }
      .post-desc { color: var(--text-muted); font-size: 0.95rem; line-height: 1.5; }

      /* Footer */
      .site-footer {
        background: var(--sec-foot);
        margin-top: 0;
        padding: 3rem clamp(1rem, 5vw, 3rem) 1.5rem;
        color: var(--text-muted);
      }
      .foot-cols {
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
        gap: 2rem;
        max-width: 1040px;
        margin: 0 auto;
      }
      @media (max-width: 760px) {
        .foot-cols { grid-template-columns: 1fr 1fr; gap: 1.75rem; }
      }
      @media (max-width: 440px) {
        .foot-cols { grid-template-columns: 1fr; }
      }
      .foot-brandline { display: flex; align-items: center; gap: 0.55rem; }
      .foot-brand strong { color: var(--text); font-family: var(--dps-font-display); }
      .foot-brand p { margin: 0.6rem 0 0; line-height: 1.5; max-width: 28ch; }
      .foot-col { display: flex; flex-direction: column; gap: 0.55rem; }
      .foot-col h4 {
        margin: 0 0 0.3rem;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text);
      }
      .foot-col a { text-decoration: none; color: var(--text-muted); font-size: 0.95rem; }
      .foot-col a:hover { color: var(--accent-strong); }
      .foot-social { display: flex; gap: 0.4rem; margin-top: 0.4rem; margin-left: -0.4rem; }
      .foot-bottom {
        max-width: 1040px;
        margin: 2.5rem auto 0;
        padding-top: 1.25rem;
        border-top: 1px solid var(--nav-border);
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        font-size: 0.9rem;
      }
      .foot-bottom a { color: var(--text-muted); }
      .foot-bottom a:hover { color: var(--accent-strong); }
    </style>
  </body>
</html>
