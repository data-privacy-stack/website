    <script is:inline>
      const tbtn = document.getElementById("theme-toggle");
      tbtn?.addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem("starlight-theme", next); } catch (e) {}
      });

      // Mobile hamburger menu
      const nav = document.querySelector(".nav");
      const mbtn = document.getElementById("menu-toggle");
      const setMenu = (open) => {
        nav.classList.toggle("open", open);
        mbtn?.setAttribute("aria-expanded", open ? "true" : "false");
      };
      mbtn?.addEventListener("click", () =>
        setMenu(!nav.classList.contains("open"))
      );
      // Close after choosing a destination
      document
        .querySelectorAll("#nav-links a")
        .forEach((a) => a.addEventListener("click", () => setMenu(false)));
      // Close on Escape
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setMenu(false);
      });

      // Scroll reveal — reveal each target once as it enters the viewport.
      (function () {
        if (!document.documentElement.classList.contains("reveal-ready")) return;
        const sel = [
          ".hero .site-title",
          ".hero .hero-logo-wrap",
          ".hero .hero-copy",
          ".section h2",
          ".section .mission-statement",
          ".section .lead",
          ".section .more",
          ".section .card",
          ".section .eco-logos li",
          ".posts li",
        ].join(",");
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        document.querySelectorAll(sel).forEach((el) => io.observe(el));
      })();
    </script>

    <style>
      :root {
        --page-bg: var(--dps-bg);
        --text: var(--dps-ink);
        --text-muted: var(--dps-muted);
        --card-bg: #ffffff;
        --card-border: var(--dps-border);
        --card-border-hover: #d7dae3;
        --accent: var(--dps-indigo);
        --accent-strong: var(--dps-indigo-dark);
        --nav-bg: rgba(251, 251, 253, 0.82);
        --nav-border: rgba(17, 19, 26, 0.08);
        --hero-radius: 0px;
        --hero-shadow: none;
        /* gentle section rhythm: page canvas alternating with a faint tint */
        --sec-a: transparent;
        --sec-b: #f4f5f9;
        --sec-foot: #f4f5f9;
      }
      :root[data-theme="dark"] {
        --page-bg: #0e1116;
        --text: #e8eaf0;
        --text-muted: #9aa3b2;
        --card-bg: #161a22;
        --card-border: #232936;
        --card-border-hover: #2d3442;
        --accent: #8b83ff;
        --accent-strong: #b7b1ff;
        --nav-bg: rgba(14, 17, 22, 0.82);
        --nav-border: rgba(255, 255, 255, 0.07);
        --hero-radius: 0px;
        --hero-shadow: none;
        --sec-a: transparent;
        --sec-b: #12151c;
        --sec-foot: #0b0e13;
      }

      /* ---- Scroll reveal — transform+opacity only, custom ease-out.
         Hidden state is gated behind html.reveal-ready, which the head
         script adds ONLY when motion is allowed + IO is supported, so
         reduced-motion / no-JS users always see fully-visible content. ---- */
      html.reveal-ready :where(
        .hero .site-title,
        .hero .hero-logo-wrap,
        .hero .hero-copy,
        .section h2,
        .section .mission-statement,
        .section .lead,
        .section .more,
        .section .card,
        .section .eco-logos li,
        .posts li
      ) {
        opacity: 0;
        transform: translate3d(var(--rx, 0px), var(--ry, 24px), 0);
        transition:
          opacity 700ms var(--ease-out),
          transform 700ms var(--ease-out);
        transition-delay: var(--reveal-delay, 0ms);
      }
      html.reveal-ready .is-visible {
        opacity: 1;
        transform: none;
      }
      /* Stagger grouped children (30-80ms steps) */
      .cards > .card:nth-child(2) { --reveal-delay: 70ms; }
      .cards > .card:nth-child(3) { --reveal-delay: 140ms; }
      .cards > .card:nth-child(4) { --reveal-delay: 210ms; }
      .posts li:nth-child(2) { --reveal-delay: 60ms; }
      .posts li:nth-child(3) { --reveal-delay: 120ms; }
      .posts li:nth-child(4) { --reveal-delay: 180ms; }
      .posts li:nth-child(5) { --reveal-delay: 240ms; }
      .eco-logos li:nth-child(2) { --reveal-delay: 70ms; }
      .eco-logos li:nth-child(3) { --reveal-delay: 140ms; }
      .eco-logos li:nth-child(4) { --reveal-delay: 210ms; }

      /* Directional entrances — content glides in from the sides,
         headings rise. (--rx/--ry feed the reveal transform above.) */
      .hero .hero-logo-wrap { --rx: -56px; --ry: 0px; }
      .hero .hero-copy { --rx: 56px; --ry: 0px; }
      .cards > .card { --ry: 0px; }
      .cards > .card:nth-child(odd) { --rx: -52px; }
      .cards > .card:nth-child(even) { --rx: 52px; }
      .posts li { --rx: -40px; --ry: 0px; }
      @media (max-width: 880px) {
        .hero .hero-logo-wrap { --rx: -28px; }
        .hero .hero-copy { --rx: 28px; }
        .cards > .card:nth-child(odd) { --rx: -28px; }
        .cards > .card:nth-child(even) { --rx: 28px; }
        .posts li { --rx: -28px; }
      }

      /* Section headings draw a small brand underline as they reveal */
      .section h2 { position: relative; }
      .section h2::after {
        content: "";
        display: block;
        width: 48px;
        height: 3px;
        margin: 0.6rem auto 0;
        border-radius: 3px;
        background: var(--dps-gradient);
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 520ms var(--ease-out) 140ms;
      }
      html.reveal-ready .section h2.is-visible::after { transform: scaleX(1); }
      html:not(.reveal-ready) .section h2::after { transform: scaleX(1); }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; overflow-x: clip; }
      body {
        margin: 0;
        font-family: var(--dps-font);
        color: var(--text);
        background: var(--page-bg);
        background-attachment: fixed;
        min-height: 100vh;
